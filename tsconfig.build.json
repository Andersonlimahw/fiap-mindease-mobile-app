
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false
  },
  "exclude": [
    "node_modules",
    "android",
    "ios",
    "src/core/ai/**/*",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
